// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ArtistSnapshot {
  id               String   @id @default(cuid())
  artistName       String
  country          String   @default("global")
  rank             Int
  monthlyListeners Int
  listenersDelta   Int?
  createdAt        DateTime @default(now())
  
  @@index([createdAt])
  @@index([artistName])
  @@index([country])
}

model ArtistCurrent {
  id               String   @id @default(cuid())
  artistId         String?  // Spotify ID if matched
  artistName       String
  country          String   @default("global") // "global" or country code like "id"
  rank             Int
  previousRank     Int?
  rankDelta        Int?     // negative = moved up, positive = moved down
  monthlyListeners Int
  listenersDelta   Int?
  imageUrl         String?
  genres           String?  @db.Text // JSON array as string
  spotifyUrl       String?
  
  // Enhanced metadata for About section
  followers        Int?     // Spotify followers count
  popularity       Int?     // Spotify popularity score (0-100)
  images           String?  @db.Text // JSON array of image URLs with different sizes
  biography        String?  @db.Text // Artist biography from Wikipedia
  socialLinks      String?  @db.Text // JSON object {facebook, instagram, twitter}
  originCountry    String?  // Artist's country of origin
  countryCode      String?  // ISO 3166-1 alpha-2 country code for flag
  birthDate        String?  // Artist's birth date
  
  // Last.fm Data
  topTracks        String?  @db.Text // JSON array of top tracks {name, playcount, listeners, url, spotifyUrl, spotifyPlayCount}
  topAlbums        String?  @db.Text // JSON array of top albums {name, playcount, url, image}
  similarArtists   String?  @db.Text // JSON array of similar artists {name, url, image}

  peakRank         Int?
  peakRankDate     DateTime?
  firstSeenDate    DateTime?

  lastUpdated      DateTime @default(now()) @updatedAt
  
  @@unique([artistName, country])
  @@index([rank])
  @@index([artistName])
  @@index([country])
}

model BlogPost {
  id        String   @id @default(cuid())
  date      DateTime @unique // One post per day
  headline  String   @db.VarChar(500)
  content   String   @db.Text // JSON string of the DailyBriefing object
  createdAt DateTime @default(now())
  
  @@index([date])
}

model TrackSnapshot {
  id           String   @id @default(cuid())
  trackName    String
  artistName   String
  country      String   @default("global")
  rank         Int
  dailyStreams BigInt
  totalStreams BigInt?
  createdAt    DateTime @default(now())
  
  @@index([createdAt])
  @@index([trackName, artistName])
  @@index([country])
}

model TrackCurrent {
  id           String   @id @default(cuid())
  trackId      String? // Spotify ID if matched
  trackName    String
  artistName   String
  country      String   @default("global") // "global" or country code like "id"
  rank         Int
  previousRank Int?
  rankDelta    Int?     // negative = moved up, positive = moved down
  dailyStreams BigInt
  totalStreams BigInt?
  imageUrl     String?
  previewUrl   String?
  spotifyUrl   String?
  lastUpdated  DateTime @default(now()) @updatedAt
  
  @@unique([trackName, artistName, country])
  @@index([rank])
  @@index([trackName, artistName])
  @@index([country])
}

